{
  "name": "ledgix-ts",
  "version": "0.4.0",
  "description": "Ledgix ALCV — TypeScript SDK for SOX 404 compliance enforcement on AI agent tool calls",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/langchain": {
      "import": {
        "types": "./dist/adapters/langchain.d.ts",
        "default": "./dist/adapters/langchain.js"
      },
      "require": {
        "types": "./dist/adapters/langchain.d.ts",
        "default": "./dist/adapters/langchain.cjs"
      }
    },
    "./adapters/llamaindex": {
      "import": {
        "types": "./dist/adapters/llamaindex.d.ts",
        "default": "./dist/adapters/llamaindex.js"
      },
      "require": {
        "types": "./dist/adapters/llamaindex.d.ts",
        "default": "./dist/adapters/llamaindex.cjs"
      }
    },
    "./adapters/vercel-ai": {
      "import": {
        "types": "./dist/adapters/vercel-ai.d.ts",
        "default": "./dist/adapters/vercel-ai.js"
      },
      "require": {
        "types": "./dist/adapters/vercel-ai.d.ts",
        "default": "./dist/adapters/vercel-ai.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jose": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.0.0",
    "msw": "^2.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "ai": ">=3.0.0",
    "llamaindex": ">=0.5.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "llamaindex": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "keywords": [
    "ledgix",
    "alcv",
    "compliance",
    "sox",
    "ai-agent",
    "jwt",
    "vault",
    "langchain",
    "llamaindex",
    "vercel-ai"
  ]
}
